---
import type { Product } from '@/types';
import { getProductThumbnail } from '@/repositories/catalog';
import { getBase } from '@/config';

interface Props {
  product: Product;
  /** Tailwind classes on the root link */
  className?: string;
}

const {
  product,
  className = ''
} = Astro.props;

const thumbnail = getProductThumbnail(product);
const base = getBase();
const routeKey = product.item_code || product.folder_name;
---

<a href={`${base}/products/${encodeURIComponent(routeKey)}`} class={`group block origin-center rounded-md transition-transform duration-200 ease-out hover:scale-[1.02] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ${className}`}>
  <div class="relative aspect-square w-full overflow-hidden rounded-md border border-border bg-muted">
    {(product.top_item ?? product.hot_item) && (
      <span class="pointer-events-none absolute right-1.5 top-1.5 z-10 inline-flex items-center rounded-full bg-orange-500 px-2 py-0.5 text-[10px] font-semibold leading-none text-white shadow-sm">
        Top items
      </span>
    )}
    <img
      src={thumbnail}
      alt={product.item_name}
      class="h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
      loading="lazy"
    />
  </div>
  <p class="mt-2 px-0.5 text-center text-[11px] font-normal leading-snug text-muted-foreground line-clamp-3 group-hover:text-foreground transition-colors">
    {product.item_name}
  </p>
</a>
