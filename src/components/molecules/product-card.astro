---
import { Card, Badge } from '@/components/ui';
import type { Product } from '@/types';
import { getProductThumbnail } from '@/repositories/catalog';
import { getBase } from '@/config';

interface Props {
  product: Product;
  showCategory?: boolean;
  showSubcategory?: boolean;
  className?: string;
}

const { 
  product, 
  showCategory = true, 
  showSubcategory = false,
  className = ""
} = Astro.props;

const thumbnail = getProductThumbnail(product);
const base = getBase();
---

<a href={`${base}/products/${product.folder_name}`} class="block">
  <Card class={`product-card overflow-hidden hover:shadow-lg transition-all hover:-translate-y-1 cursor-pointer ${className}`}>
    <!-- Product Image -->
    <div class="aspect-square bg-muted relative overflow-hidden">
      <img 
        src={thumbnail} 
        alt={product.item_name}
        class="w-full h-full object-cover transition-transform duration-300 ease-in-out product-image"
        loading="lazy"
      />
      
      <!-- Hot Item Badge (top-right) -->
      {product.hot_item && (
        <div class="absolute top-2 right-2">
          <Badge variant="destructive" class="bg-orange-500 hover:bg-orange-600 text-xs">
            Hot
          </Badge>
        </div>
      )}
    </div>
    
    <!-- Product Information -->
    <div class="p-4 space-y-3">
      <div class="space-y-2">
        <!-- Category/Subcategory Badges -->
        {(showCategory || showSubcategory) && (
          <div class="flex items-center gap-2 flex-wrap">
            {showCategory && (
              <Badge variant="secondary" class="text-xs">
                {product.category_main.replace('-', ' ')}
              </Badge>
            )}
            {showSubcategory && (
              <Badge variant="outline" class="text-xs">
                {product.category_sub.replace('-', ' ')}
              </Badge>
            )}
          </div>
        )}
        
        <!-- Product Name -->
        <h3 class="font-semibold text-lg leading-tight line-clamp-2">
          {product.item_name}
        </h3>
        
        <!-- Product Code -->
        {product.item_code && (
          <p class="text-xs text-muted-foreground font-mono">
            {product.item_code}
          </p>
        )}
        
        <!-- Description -->
        <p class="text-sm text-muted-foreground line-clamp-2">
          {product.item_description}
        </p>
        
        
        <!-- Tags (first 3) -->
        {product.tag_visible && product.tag_visible.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {product.tag_visible.slice(0, 3).map((tag) => (
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
            {product.tag_visible.length > 3 && (
              <span class="text-xs text-gray-500">
                +{product.tag_visible.length - 3} more
              </span>
            )}
          </div>
        )}
      </div>
    </div>
    
    <!-- Hover Overlay -->
    <div class="absolute inset-0 bg-black bg-opacity-0 hover:bg-opacity-10 transition-all duration-300 flex items-center justify-center opacity-0 hover:opacity-100">
      <span class="text-white font-medium bg-blue-600 px-4 py-2 rounded-lg transform translate-y-2 hover:translate-y-0 transition-transform duration-300">
        View Details
      </span>
    </div>
  </Card>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .product-card {
    position: relative;
  }
  
  .product-card:hover .product-image {
    transform: scale(1.05);
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .product-card {
      margin-bottom: 1rem;
    }
  }
</style>