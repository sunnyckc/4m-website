---
import type { MultiLanguage } from '@/types';

interface Props {
  multiLanguage: MultiLanguage[];
  itemCode: string;
}

const { multiLanguage, itemCode } = Astro.props;

function resolveUrl(item: MultiLanguage): string {
  if (item.media_source === 'file') {
    return `/manuals/${itemCode}/${item.media_destination}`;
  }
  return item.media_destination;
}

const downloadOptions = multiLanguage.map(item => ({
  language: item.language,
  url: resolveUrl(item),
}));
---

{downloadOptions.length > 0 && (
  <div class="flex items-center space-x-2">
    <span class="text-sm font-medium text-muted-foreground font-comic-neue whitespace-nowrap">Multi-language:</span>
    <select
      id="manual-language-select"
      class="text-sm rounded-md border border-input bg-background px-2 py-1 font-comic-neue focus:outline-none focus:ring-1 focus:ring-ring"
    >
      {downloadOptions.map((opt) => (
        <option value={opt.url}>{opt.language}</option>
      ))}
    </select>
    <button
      id="manual-download-btn"
      type="button"
      class="text-primary hover:text-primary/80 transition-colors"
      title="Download"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
      </svg>
    </button>
  </div>
)}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const select = document.getElementById('manual-language-select') as HTMLSelectElement | null;
    const btn = document.getElementById('manual-download-btn');
    if (!select || !btn) return;

    btn.addEventListener('click', function() {
      const url = select.value;
      if (!url) return;
      const a = document.createElement('a');
      a.href = url;
      a.download = '';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    });
  });
</script>
