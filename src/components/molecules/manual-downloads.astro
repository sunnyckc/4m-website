---
import type { MultiLanguage } from '@/types';
import { getBase } from '@/config';

interface Props {
  multiLanguage: MultiLanguage[];
  itemCode: string;
}

const { multiLanguage, itemCode } = Astro.props;
const base = getBase();

function resolveUrl(item: MultiLanguage): string {
  if (item.media_source === 'file') {
    return `/manuals/${itemCode}/${item.media_destination}`;
  }
  return item.media_destination;
}

const downloadOptions = multiLanguage.map(item => ({
  language: item.language,
  url: resolveUrl(item),
}));
---

{downloadOptions.length > 0 && (
  <div class="flex items-center space-x-2" data-manual-download-root data-base={base}>
    <span class="text-sm font-medium text-muted-foreground font-comic-neue whitespace-nowrap">Multi-language:</span>
    <select
      id="manual-language-select"
      class="text-sm rounded-md border border-input bg-background px-2 py-1 font-comic-neue focus:outline-none focus:ring-1 focus:ring-ring"
    >
      {downloadOptions.map((opt) => (
        <option value={opt.url}>{opt.language}</option>
      ))}
    </select>
    <button
      id="manual-download-btn"
      type="button"
      class="text-primary hover:text-primary/80 transition-colors"
      title="Download"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
      </svg>
    </button>
  </div>
)}

<script>
  function initManualDownloads() {
    const select = document.getElementById('manual-language-select') as HTMLSelectElement | null;
    const btn = document.getElementById('manual-download-btn');
    if (!select || !btn) return;
    const root = btn.closest('[data-manual-download-root]') as HTMLElement | null;
    const base = root?.getAttribute('data-base') ?? '';

    function fileNameFromUrl(url: string, fallback = 'manual.pdf'): string {
      try {
        const parsed = new URL(url);
        const path = parsed.pathname;
        const last = path.split('/').filter(Boolean).pop();
        return last || fallback;
      } catch {
        return fallback;
      }
    }

    btn.addEventListener('click', async function() {
      const url = select.value;
      if (!url) return;
      const selectedLabel = select.options[select.selectedIndex]?.text || 'manual';
      const baseName = fileNameFromUrl(url, `${selectedLabel}.pdf`);
      const safeLang = selectedLabel.replace(/[^a-zA-Z0-9-_]+/g, '-');
      const fileName = `${safeLang}-${baseName}`;
      const proxyUrl = `${base}/api/download?url=${encodeURIComponent(url)}&filename=${encodeURIComponent(fileName)}`;
      try {
        const res = await fetch(proxyUrl, { method: 'GET' });
        if (!res.ok) throw new Error('Download failed');
        const blob = await res.blob();
        const objectUrl = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = objectUrl;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(objectUrl);
      } catch (e) {
        console.error('[manual-download] Failed to download file', e);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initManualDownloads, { once: true });
  } else {
    initManualDownloads();
  }
</script>
