---
export interface CollageItem {
  id: string;
  title?: string;
  image?: string;
  backgroundColor?: string;
  textColor?: string;
  href?: string;
}

export interface Props {
  mainItem: CollageItem;
  smallItems: CollageItem[];
  class?: string;
}

const { 
  mainItem,
  smallItems = [],
  class: className = ""
} = Astro.props;

import { CollageItem } from '@/components/molecules';
import { cn } from '@/utils';

// Ensure we have exactly 5 small items for the layout
const displayItems = smallItems.slice(0, 5);
while (displayItems.length < 5) {
  displayItems.push({
    id: `placeholder-${displayItems.length}`,
    backgroundColor: `bg-gradient-to-br from-gray-400 to-gray-600`
  });
}
---

<div class={cn("w-full", className)}>
  <!-- Desktop Layout: 3x3 Grid - Perfect Square with Small Gaps -->
  <div class="hidden md:grid grid-cols-3 grid-rows-3 gap-2 aspect-square max-w-4xl mx-auto">
    <!-- Main Item: 2x2 (top-left) -->
    <div class="col-span-2 row-span-2">
      <CollageItem 
        title={mainItem.title}
        image={mainItem.image}
        backgroundColor={mainItem.backgroundColor || "bg-gradient-to-br from-indigo-600 to-purple-700"}
        textColor={mainItem.textColor}
        href={mainItem.href}
        class="h-full"
      />
    </div>
    
    <!-- Small Item 1: Top-right -->
    <div class="col-start-3 row-start-1">
      <CollageItem 
        title={displayItems[0].title}
        image={displayItems[0].image}
        backgroundColor={displayItems[0].backgroundColor}
        textColor={displayItems[0].textColor}
        href={displayItems[0].href}
      />
    </div>
    
    <!-- Small Item 2: Middle-right -->
    <div class="col-start-3 row-start-2">
      <CollageItem 
        title={displayItems[1].title}
        image={displayItems[1].image}
        backgroundColor={displayItems[1].backgroundColor}
        textColor={displayItems[1].textColor}
        href={displayItems[1].href}
      />
    </div>
    
    <!-- Small Item 3: Bottom-left -->
    <div class="col-start-1 row-start-3">
      <CollageItem 
        title={displayItems[2].title}
        image={displayItems[2].image}
        backgroundColor={displayItems[2].backgroundColor}
        textColor={displayItems[2].textColor}
        href={displayItems[2].href}
      />
    </div>
    
    <!-- Small Item 4: Bottom-center -->
    <div class="col-start-2 row-start-3">
      <CollageItem 
        title={displayItems[3].title}
        image={displayItems[3].image}
        backgroundColor={displayItems[3].backgroundColor}
        textColor={displayItems[3].textColor}
        href={displayItems[3].href}
      />
    </div>
    
    <!-- Small Item 5: Bottom-right -->
    <div class="col-start-3 row-start-3">
      <CollageItem 
        title={displayItems[4].title}
        image={displayItems[4].image}
        backgroundColor={displayItems[4].backgroundColor}
        textColor={displayItems[4].textColor}
        href={displayItems[4].href}
      />
    </div>
  </div>

  <!-- Mobile Layout: Square Grid -->
  <div class="md:hidden">
    <!-- Main Item -->
    <div class="aspect-square mb-0">
      <CollageItem 
        title={mainItem.title}
        image={mainItem.image}
        backgroundColor={mainItem.backgroundColor || "bg-gradient-to-br from-indigo-600 to-purple-700"}
        textColor={mainItem.textColor}
        href={mainItem.href}
        class="h-full"
      />
    </div>
    
    <!-- Small Items in 2x3 Grid on Mobile -->
    <div class="grid grid-cols-2 gap-2">
      {displayItems.map((item) => (
        <CollageItem 
          title={item.title}
          image={item.image}
          backgroundColor={item.backgroundColor}
          textColor={item.textColor}
          href={item.href}
        />
      ))}
    </div>
  </div>
</div>