---
export interface HeroSlide {
  id: string;
  image: string;
  title: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  ctaVariant?: "default" | "outline";
}

export interface Props {
  slides: HeroSlide[];
  autoplay?: boolean;
  autoplayInterval?: number;
  showIndicators?: boolean;
  showArrows?: boolean;
  height?: string;
  class?: string;
}

const { 
  slides = [],
  autoplay = true,
  autoplayInterval = 5000,
  showIndicators = true,
  showArrows = true,
  height = "h-auto",
  class: className = ""
} = Astro.props;

import { Button } from '@/components/ui';
import { cn } from '@/utils';
---

<div 
  class={cn("relative overflow-hidden h-[370px]", className)}
  x-data={`{
    currentSlide: 0,
    slides: ${JSON.stringify(slides)},
    autoplay: ${autoplay},
    interval: ${autoplayInterval},
    timer: null,
    
    init() {
      console.log('Slideshow initialized with', this.slides.length, 'slides');
      if (this.autoplay && this.slides.length > 1) {
        this.startAutoplay();
      }
    },
    
    startAutoplay() {
      this.timer = setInterval(() => {
        this.nextSlide();
      }, this.interval);
    },
    
    stopAutoplay() {
      if (this.timer) {
        clearInterval(this.timer);
        this.timer = null;
      }
    },
    
    nextSlide() {
      this.currentSlide = (this.currentSlide + 1) % this.slides.length;
    },
    
    prevSlide() {
      this.currentSlide = this.currentSlide === 0 ? this.slides.length - 1 : this.currentSlide - 1;
    },
    
    goToSlide(index) {
      console.log('Going to slide', index, 'current:', this.currentSlide);
      if (index >= 0 && index < this.slides.length) {
        this.currentSlide = index;
      } else {
        console.warn('Invalid slide index:', index, 'max:', this.slides.length - 1);
      }
    }
  }`}
  @mouseenter="stopAutoplay()"
  @mouseleave="autoplay && startAutoplay()"
>
  <!-- Slides Container -->
  <div class="relative w-full h-[370px]">
    {slides.map((slide, index) => (
      <div 
        class="absolute top-0 left-0 w-full h-full transition-opacity duration-500 ease-in-out"
        x-show={`currentSlide === ${index}`}
        x-transition:enter="transition-opacity duration-500"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity duration-500"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
      >
        <!-- Image anchored to left, cropped on right if too big -->
        <img 
          src={slide.image} 
          alt={slide.title || `Slide ${index + 1}`}
          class="w-full h-full object-cover object-left block"
          loading={index === 0 ? "eager" : "lazy"}
        />
      </div>
    ))}
  </div>

  <!-- Navigation Arrows (hidden but functionality preserved) -->
  {showArrows && slides.length > 1 && (
    <>
      <!-- Previous Arrow (invisible) -->
      <button
        @click="prevSlide()"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-20 p-2 opacity-0 pointer-events-none"
        aria-label="Previous slide"
        style="display: none;"
      >
      </button>

      <!-- Next Arrow (invisible) -->
      <button
        @click="nextSlide()"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-20 p-2 opacity-0 pointer-events-none"
        aria-label="Next slide"
        style="display: none;"
      >
      </button>
    </>
  )}

  <!-- Indicators -->
  {showIndicators && slides.length > 1 && (
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex space-x-2">
      {slides.map((_, index) => (
        <button
          @click={`goToSlide(${index})`}
          class="w-3 h-3 rounded-full transition-all duration-300"
          :class={`currentSlide === ${index} ? 'bg-white' : 'bg-white/50 hover:bg-white/70'`}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  )}
</div>

<style>
  /* Ensure smooth transitions */
  [x-cloak] { 
    display: none !important; 
  }
</style>