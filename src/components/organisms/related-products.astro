---
import type { Product } from '@/types';
import { getProductThumbnail } from '@/repositories/catalog';
import { getBase } from '@/config';

interface Props {
  products: Product[];
}

const { products } = Astro.props;
const base = getBase();
---

{products.length > 0 && (
  <section class="related-products py-12 border-t border-border">
    <h2 class="text-2xl font-bold text-foreground mb-8 font-fredoka">Related Products</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => (
          <div class="product-card">
            <a href={`${base}/products/${product.folder_name}`} class="block">
              <div class="relative overflow-hidden rounded-2xl bg-white shadow-md transition-shadow duration-300 hover:shadow-lg">
                <!-- Product Image -->
                <div class="aspect-square overflow-hidden">
                  <img 
                    src={getProductThumbnail(product)}
                    alt={product.item_name}
                    class="h-full w-full object-cover"
                  />
                </div>
                
                <!-- White Banner with Product Name -->
                <div class="absolute bottom-0 left-0 right-0 bg-white bg-opacity-95 backdrop-blur-sm border-t border-gray-200">
                  <div class="px-3 py-2">
                    <h3 class="text-sm font-medium text-gray-900 text-center truncate font-fredoka">
                      {product.item_name}
                    </h3>
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
  </section>
)}

<style>
  .product-card {
    position: relative;
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
  
  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>