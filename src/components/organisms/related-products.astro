---
import type { Product } from '@/types';
import { getProductHref } from '@/lib/product-routing';
import { getProductThumbnail } from '@/repositories/catalog';
import { getBase } from '@/config';

interface Props {
  products: Product[];
}

const { products } = Astro.props;
const base = getBase();
---

{products.length > 0 && (
  <section class="related-products py-12 border-t border-border">
    <h2 class="text-2xl font-bold text-foreground mb-8 font-fredoka">Related Products</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => (
          <div class="product-card">
            <a href={getProductHref(product, base)} data-product-id={product.id ?? undefined} class="block">
              <div class="overflow-hidden rounded-2xl bg-white shadow-md transition-shadow duration-300 hover:shadow-lg">
                <div class="aspect-square overflow-hidden rounded-t-2xl">
                  <img
                    src={getProductThumbnail(product)}
                    alt={product.item_name}
                    class="h-full w-full object-cover"
                  />
                </div>
                <div class="border-t border-border px-3 py-2.5">
                  <h3 class="text-sm font-medium text-foreground text-center line-clamp-2 font-fredoka">
                    {product.item_name}
                  </h3>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
  </section>
)}

<style>
  .product-card {
    position: relative;
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
  
  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>