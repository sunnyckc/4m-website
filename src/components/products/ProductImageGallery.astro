---
import type { ProductMedia } from '../../data/helpers';

interface Props {
  media: ProductMedia[];
  folderName: string;
  productName: string;
}

const { media, folderName, productName } = Astro.props;

function resolveUrl(m: ProductMedia): string {
  if (m.media_source === 'file') {
    return `/images/products/${folderName}/${m.media_destination}`;
  }
  return m.media_destination;
}

function resolveEmbed(m: ProductMedia): string {
  if (m.media_source === 'vimeo') {
    return `https://player.vimeo.com/video/${m.media_destination}`;
  }
  if (m.media_source === 'wistia') {
    return `https://fast.wistia.net/embed/iframe/${m.media_destination}`;
  }
  return m.media_destination;
}

interface GalleryItem {
  type: 'image' | 'video' | 'award';
  mediaSource: string;
  src: string;
  embedSrc: string;
}

const visibleMedia = media
  .filter(m => !m.hidden)
  .sort((a, b) => a.sequence - b.sequence);

const galleryItems: GalleryItem[] = visibleMedia.map(m => ({
  type: m.type,
  mediaSource: m.media_source,
  src: resolveUrl(m),
  embedSrc: (m.media_source === 'vimeo' || m.media_source === 'wistia') ? resolveEmbed(m) : resolveUrl(m),
}));

const firstItem = galleryItems[0];
const isFirstImage = firstItem && (firstItem.type === 'image' || firstItem.type === 'award');
---

<div class="product-image-gallery">
  <!-- Main Display -->
  <div class="main-display-container relative mb-4 rounded-lg shadow-lg overflow-hidden bg-muted aspect-[4/3]">
    <!-- Image display -->
    <img
      id="main-product-image"
      src={isFirstImage ? firstItem.src : ''}
      alt={productName}
      class={`w-full h-full object-cover transition-all duration-300 ${isFirstImage ? '' : 'hidden'}`}
    />
    <!-- Video (file / url) display -->
    <video
      id="main-product-video"
      class="w-full h-full object-contain hidden"
      controls
      preload="metadata"
    >
      <source id="main-video-source" src="" type="video/mp4" />
    </video>
    <!-- Embed (vimeo / wistia) display -->
    <iframe
      id="main-product-embed"
      class="w-full h-full hidden"
      src=""
      frameborder="0"
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>

  <!-- Thumbnail Strip -->
  {galleryItems.length > 1 && (
    <div class="thumbnail-gallery">
      <div class="flex space-x-2 overflow-x-auto pb-2">
        {galleryItems.map((item, index) => (
          <button
            type="button"
            class={`thumbnail-btn relative flex-shrink-0 w-20 h-20 rounded-md overflow-hidden border-2 transition-all duration-200 ${
              index === 0 ? 'border-blue-500 ring-2 ring-blue-200' : 'border-gray-200 hover:border-gray-300'
            }`}
            data-index={index}
          >
            {(item.type === 'image' || item.type === 'award') && (
              <img
                src={item.src}
                alt={`${productName} ${item.type} ${index + 1}`}
                class="w-full h-full object-cover"
              />
            )}
            {item.type === 'video' && (
              <>
                <div class="w-full h-full bg-gray-800 flex items-center justify-center">
                  <svg class="w-8 h-8 text-white opacity-80" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </>
            )}
            {item.type === 'award' && (
              <div class="absolute top-0.5 right-0.5">
                <svg class="w-3.5 h-3.5 text-yellow-500 drop-shadow" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              </div>
            )}
          </button>
        ))}
      </div>
    </div>
  )}

  <!-- Counter -->
  {galleryItems.length > 1 && (
    <div class="image-counter mt-2 text-sm text-gray-600 text-center">
      <span id="current-image">1</span> / <span id="total-images">{galleryItems.length}</span>
    </div>
  )}

  <!-- Zoom Modal (images/awards only) -->
  <div id="zoom-modal" class="fixed inset-0 bg-black bg-opacity-75 z-50 hidden items-center justify-center p-4">
    <div class="relative max-w-4xl max-h-full">
      <button
        id="close-zoom"
        class="absolute top-4 right-4 text-white text-2xl hover:text-gray-300 z-10"
        type="button"
      >
        ✕
      </button>
      <img
        id="zoomed-image"
        src=""
        alt=""
        class="max-w-full max-h-full object-contain"
      />
      {galleryItems.length > 1 && (
        <>
          <button
            id="prev-image"
            class="absolute left-4 top-1/2 transform -translate-y-1/2 text-white text-2xl hover:text-gray-300"
            type="button"
          >
            ‹
          </button>
          <button
            id="next-image"
            class="absolute right-4 top-1/2 transform -translate-y-1/2 text-white text-2xl hover:text-gray-300"
            type="button"
          >
            ›
          </button>
        </>
      )}
    </div>
  </div>
</div>

<script define:vars={{ galleryItems }}>
  document.addEventListener('DOMContentLoaded', function() {
    const items = galleryItems;
    const mainImage = document.getElementById('main-product-image');
    const mainVideo = document.getElementById('main-product-video');
    const mainVideoSource = document.getElementById('main-video-source');
    const mainEmbed = document.getElementById('main-product-embed');
    const thumbnailBtns = document.querySelectorAll('.thumbnail-btn');
    const currentImageSpan = document.getElementById('current-image');
    const zoomModal = document.getElementById('zoom-modal');
    const zoomedImage = document.getElementById('zoomed-image');
    const closeZoom = document.getElementById('close-zoom');
    const prevBtn = document.getElementById('prev-image');
    const nextBtn = document.getElementById('next-image');

    let currentIndex = 0;

    function showItem(index) {
      const item = items[index];
      if (!item) return;

      mainImage.classList.add('hidden');
      mainVideo.classList.add('hidden');
      mainEmbed.classList.add('hidden');
      mainVideo.pause();

      if (item.type === 'image' || item.type === 'award') {
        mainImage.src = item.src;
        mainImage.classList.remove('hidden');
      } else if (item.type === 'video') {
        if (item.mediaSource === 'vimeo' || item.mediaSource === 'wistia') {
          mainEmbed.src = item.embedSrc;
          mainEmbed.classList.remove('hidden');
        } else {
          mainVideoSource.src = item.src;
          mainVideo.load();
          mainVideo.classList.remove('hidden');
        }
      }

      thumbnailBtns.forEach(function(btn, i) {
        btn.classList.remove('border-blue-500', 'ring-2', 'ring-blue-200');
        btn.classList.add('border-gray-200');
        if (i === index) {
          btn.classList.remove('border-gray-200');
          btn.classList.add('border-blue-500', 'ring-2', 'ring-blue-200');
        }
      });

      if (currentImageSpan) {
        currentImageSpan.textContent = (index + 1).toString();
      }

      currentIndex = index;
    }

    thumbnailBtns.forEach(function(btn, index) {
      btn.addEventListener('click', function() {
        showItem(index);
      });
    });

    // Click main image to zoom (only for image/award)
    if (mainImage) {
      mainImage.addEventListener('click', function() {
        var item = items[currentIndex];
        if (item && (item.type === 'image' || item.type === 'award') && zoomModal && zoomedImage) {
          zoomedImage.src = item.src;
          zoomModal.classList.remove('hidden');
          zoomModal.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }
      });
    }

    if (closeZoom) {
      closeZoom.addEventListener('click', function() {
        closeModal();
      });
    }

    if (zoomModal) {
      zoomModal.addEventListener('click', function(e) {
        if (e.target === zoomModal) closeModal();
      });
    }

    function closeModal() {
      if (zoomModal) {
        zoomModal.classList.add('hidden');
        zoomModal.classList.remove('flex');
        document.body.style.overflow = 'auto';
      }
    }

    function navigateZoom(direction) {
      // Find next image/award item in that direction (skip videos in zoom)
      var next = currentIndex;
      for (var i = 0; i < items.length; i++) {
        next = (next + direction + items.length) % items.length;
        if (items[next].type === 'image' || items[next].type === 'award') break;
      }
      showItem(next);
      if (zoomedImage) zoomedImage.src = items[next].src;
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { navigateZoom(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { navigateZoom(1); });

    document.addEventListener('keydown', function(e) {
      if (zoomModal && !zoomModal.classList.contains('hidden')) {
        if (e.key === 'Escape') closeModal();
        else if (e.key === 'ArrowLeft') navigateZoom(-1);
        else if (e.key === 'ArrowRight') navigateZoom(1);
      }
    });
  });
</script>

<style>
  .thumbnail-btn {
    cursor: pointer;
  }

  .thumbnail-btn:hover {
    transform: scale(1.05);
  }

  #main-product-image {
    cursor: zoom-in;
  }

  #zoom-modal img {
    cursor: zoom-out;
  }

  .thumbnail-gallery {
    scrollbar-width: thin;
    scrollbar-color: #cbd5e0 #f7fafc;
  }

  .thumbnail-gallery::-webkit-scrollbar {
    height: 6px;
  }

  .thumbnail-gallery::-webkit-scrollbar-track {
    background: #f7fafc;
    border-radius: 3px;
  }

  .thumbnail-gallery::-webkit-scrollbar-thumb {
    background: #cbd5e0;
    border-radius: 3px;
  }

  .thumbnail-gallery::-webkit-scrollbar-thumb:hover {
    background: #a0aec0;
  }
</style>
