---
interface Props {
  specifications: Record<string, string | string[] | undefined>;
  awards?: string[];
}

const { specifications, awards = [] } = Astro.props;

// Helper function to format specification keys for display
function formatSpecKey(key: string): string {
  return key
    .split('_')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

// Get all specification entries excluding 'includes' which we'll handle separately
const specEntries = Object.entries(specifications).filter(([key]) => key !== 'includes' && specifications[key] !== undefined);
---

<section class="product-specifications py-12 bg-muted/50">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Technical Specifications -->
      <div class="bg-card rounded-2xl shadow-sm p-6 card-playful">
        <h2 class="text-xl font-bold text-foreground mb-6 flex items-center font-fredoka">
          <svg class="w-5 h-5 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Specifications
        </h2>
        
        <div class="space-y-4">
          {specEntries.map(([key, value]) => (
            <div class="flex justify-between items-start py-2 border-b border-border last:border-b-0">
              <span class="font-medium text-muted-foreground flex-shrink-0 w-1/3 font-comic-neue">
                {formatSpecKey(key)}:
              </span>
              <span class="text-foreground text-right flex-1 font-comic-neue">
                {value}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- What's Included -->
      {specifications.includes && Array.isArray(specifications.includes) && specifications.includes.length > 0 && (
        <div class="bg-card rounded-2xl shadow-sm p-6 card-playful">
          <h2 class="text-xl font-bold text-foreground mb-6 flex items-center font-fredoka">
            <svg class="w-5 h-5 mr-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            What's Included
          </h2>
          
          <ul class="space-y-3">
            {(specifications.includes as string[]).map((item) => (
              <li class="flex items-start">
                <svg class="w-4 h-4 text-accent mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-foreground font-comic-neue">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Awards Section -->
    {awards && awards.length > 0 && (
      <div class="mt-8 bg-gradient-to-r from-yellow-50 to-orange-50 rounded-lg shadow-sm p-6 border border-yellow-200">
        <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
          <svg class="w-5 h-5 mr-2 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
          </svg>
          Awards & Recognition
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {awards.map((award) => (
            <div class="flex items-start bg-white rounded-lg p-4 shadow-sm">
              <div class="flex-shrink-0 w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center mr-3">
                <svg class="w-4 h-4 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">{award}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Additional Information -->
    <div class="mt-8 bg-blue-50 rounded-lg p-6 border border-blue-200">
      <h3 class="text-lg font-semibold text-blue-900 mb-3 flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Important Information
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-blue-800">
        <div class="flex items-start">
          <svg class="w-4 h-4 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
          <span>Adult supervision recommended for children under 10</span>
        </div>
        <div class="flex items-start">
          <svg class="w-4 h-4 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>All materials are non-toxic and safe</span>
        </div>
        <div class="flex items-start">
          <svg class="w-4 h-4 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>Assembly time: 30-60 minutes</span>
        </div>
        <div class="flex items-start">
          <svg class="w-4 h-4 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9"></path>
          </svg>
          <span>Worldwide shipping available</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Smooth animations for specification items */
  .space-y-4 > div {
    transition: background-color 0.2s ease;
  }
  
  .space-y-4 > div:hover {
    background-color: #f9fafb;
    border-radius: 0.375rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
  
  /* Award cards hover effect */
  .grid > div:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition: all 0.2s ease;
  }
</style>