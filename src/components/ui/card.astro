---
import { cn } from "../../lib/utils";

export interface Props {
  class?: string;
}

const { class: className, ...props } = Astro.props;
---

<div class={cn("rounded-2xl border bg-card text-card-foreground shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1", className)} {...props}>
  <slot />
</div>