---
import BaseLayout from './base-layout.astro';
import Header from './header.astro';
import Footer from './footer.astro';
import '@/styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Hide the header until the user scrolls (e.g. full-viewport home hero). */
  revealHeaderOnScroll?: boolean;
}

const { title, description, image, revealHeaderOnScroll = false } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <div class="min-h-screen flex flex-col">
    <Header revealOnScroll={revealHeaderOnScroll} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>