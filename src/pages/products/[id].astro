---
import Layout from '../../components/layout/Layout.astro';
import ProductImageGallery from '../../components/products/ProductImageGallery.astro';
import RelatedProducts from '../../components/products/RelatedProducts.astro';
import ManualDownloads from '../../components/products/ManualDownloads.astro';
import Badge from '../../components/ui/badge.astro';
import { getProducts } from '../../data/helpers';
import type { Product } from '../../data/helpers';

export async function getStaticPaths() {
  const products = await getProducts();
  
  return products.map((product: Product) => ({
    params: { id: product.id },
    props: { product }
  }));
}

interface Props {
  product: Product;
}

const { product }: Props = Astro.props;

// Get related products (same category, different product)
const allProducts = await getProducts();
const relatedProducts = allProducts
  .filter((p: Product) => p.category === product.category && p.id !== product.id)
  .slice(0, 4);

// Mock manual downloads (in real implementation, this would come from your data)
const manualDownloads = [
  { language: 'English', url: `/manuals/${product.product_code}/english.pdf` },
  { language: 'French', url: `/manuals/${product.product_code}/french.pdf` },
  { language: 'German', url: `/manuals/${product.product_code}/german.pdf` },
  { language: 'Spanish', url: `/manuals/${product.product_code}/spanish.pdf` },
];
---

<Layout title={`${product.name} - 4M`} description={product.description}>
  <div class="container-custom py-8">
    <!-- Breadcrumb Navigation -->
    <nav class="flex items-center space-x-2 text-sm text-muted-foreground mb-6">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span>/</span>
      <a href="/products" class="hover:text-primary transition-colors">Products</a>
      <span>/</span>
      <span class="text-foreground font-medium">{product.name}</span>
    </nav>

    <!-- Product Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <!-- Product Images -->
      <div class="space-y-4">
        <ProductImageGallery 
          mainImage={product.images.main}
          galleryImages={product.images.gallery}
          productName={product.name}
        />
      </div>

      <!-- Product Information -->
      <div class="space-y-6">
        <!-- Product Code -->
        <div class="text-sm text-muted-foreground font-comic-neue">
          {product.product_code}
        </div>

        <!-- Product Title -->
        <h1 class="text-3xl md:text-4xl font-bold text-foreground font-fredoka">
          {product.name}
        </h1>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2">
          {product.hot_item && (
            <Badge variant="destructive" class="bg-orange-500 hover:bg-orange-600 font-comic-neue">Hot Item</Badge>
          )}
        </div>


        <!-- Description -->
        <div class="text-foreground leading-relaxed font-comic-neue">
          {product.description}
        </div>

        <!-- Tags -->
        <div class="space-y-2">
          <h3 class="font-semibold text-foreground font-fredoka">Tags:</h3>
          <div class="flex flex-wrap gap-2">
            {product.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-muted text-muted-foreground text-sm rounded-full font-comic-neue">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Quick Specifications -->
        <div class="bg-muted p-4 rounded-2xl space-y-2 card-playful">
          <h3 class="font-semibold text-foreground font-fredoka">Quick Info:</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm font-comic-neue">
            <div><span class="font-medium">Age Range:</span> {product.specifications.age_range}</div>
            <div><span class="font-medium">Item Size:</span> {product.specifications.item_size}</div>
            <div><span class="font-medium">Barcode:</span> {product.specifications.barcode}</div>
            <div><span class="font-medium">Packaging:</span> {product.specifications.packaging}</div>
          </div>
        </div>

        <!-- Social Sharing -->
        <div class="flex items-center space-x-4 pt-4 border-t border-border">
          <span class="text-sm font-medium text-muted-foreground font-comic-neue">Share:</span>
          <div class="flex space-x-2">
            <a href="#" class="text-primary hover:text-primary/80 transition-colors btn-bouncy">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
              </svg>
            </a>
            <a href="#" class="text-primary hover:text-primary/80 transition-colors btn-bouncy">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/>
              </svg>
            </a>
            <a href="#" class="text-destructive hover:text-destructive/80 transition-colors btn-bouncy">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.219-5.175 1.219-5.175s-.219-.438-.219-1.085c0-1.016.589-1.775 1.323-1.775.623 0 .924.466.924 1.025 0 .624-.397 1.557-.603 2.421-.171.725.363 1.315 1.077 1.315 1.295 0 2.291-1.364 2.291-3.337 0-1.745-1.254-2.965-3.046-2.965-2.074 0-3.292 1.553-3.292 3.159 0 .625.241 1.296.542 1.659.059.072.068.135.05.209-.055.227-.177.719-.201.82-.031.129-.101.158-.233.095-1.177-.549-1.913-2.273-1.913-3.658 0-2.98 2.164-5.715 6.242-5.715 3.276 0 5.825 2.334 5.825 5.453 0 3.254-2.052 5.87-4.898 5.87-.955 0-1.856-.497-2.164-1.09l-.588 2.241c-.213.828-.789 1.865-1.175 2.497C9.23 23.847 10.583 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual Downloads -->
    <ManualDownloads downloads={manualDownloads} />

    <!-- Related Products -->
    <RelatedProducts products={relatedProducts} />
  </div>
</Layout>