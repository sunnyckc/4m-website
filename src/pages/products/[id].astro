---
import { Layout } from '@/layouts';
import {
  Breadcrumb,
  ProductImageGallery,
  RelatedProducts,
  ManualDownloads,
  ProductShare,
  Badge,
} from '@/components';
import { getAllProducts, getProductDetail } from '@/services/products';
import { getProductThumbnail } from '@/repositories/catalog';
import { getBase, isProductDetailSocialEnabled } from '@/config';
import type { Product } from '@/types';

export const prerender = false;

const { id } = Astro.params;
const product = id ? await getProductDetail(id) : null;
if (!product) {
  return Astro.redirect(`${getBase()}/products`);
}
const canonicalKey = product.item_code || product.folder_name;
if (id && canonicalKey && id !== canonicalKey) {
  return Astro.redirect(`${getBase()}/products/${encodeURIComponent(canonicalKey)}`, 301);
}

let allProducts: Product[] = [];
try {
  allProducts = await getAllProducts();
} catch (e) {
  console.warn('[products] Could not load catalog for related products', e);
}
const isSelf = (p: Product) => p.item_code === product.item_code;

// 1. Start with explicitly defined related products
const explicitCodes =
  product.related_products?.map((item) => item.item_code) ?? product.related_product ?? [];
const explicit = explicitCodes
  .map(code => allProducts.find(p => p.item_code === code))
  .filter((p): p is Product => p !== undefined && !isSelf(p));

const usedCodes = new Set(explicit.map(p => p.item_code));
usedCodes.add(product.item_code);

// 2. Fill from same sub-category
const sameSub = allProducts.filter(p => !usedCodes.has(p.item_code) && p.category_sub === product.category_sub);
sameSub.forEach(p => usedCodes.add(p.item_code));

// 3. Fill from same main category
const sameMain = allProducts.filter(p => !usedCodes.has(p.item_code) && p.category_main === product.category_main);

const relatedProducts = [...explicit, ...sameSub, ...sameMain].slice(0, 4);

const thumbnail = getProductThumbnail(product);
const base = getBase();
const showProductSocial = isProductDetailSocialEnabled();
const shareLine = `Check out this amazing toy: ${product.item_name}`;
---

<Layout title={`${product.item_name} - 4M`} description={product.item_description}>
  <div class="container-custom py-8">
    <Breadcrumb
      items={[
        { label: 'Home', href: `${base}/` },
        { label: 'Products', href: `${base}/products` },
        { label: product.item_name },
      ]}
    />

    <!-- Product Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <!-- Product Images -->
      <div class="space-y-4">
        <ProductImageGallery 
          media={product.media}
          folderName={product.folder_name}
          productName={product.item_name}
        />
      </div>

      <!-- Product Information -->
      <div class="space-y-6">
        <!-- Product Code -->
        <div class="text-sm text-muted-foreground font-comic-neue">
          {product.item_code}
        </div>

        <!-- Product Title -->
        <h1 class="text-3xl md:text-4xl font-bold text-foreground font-fredoka">
          {product.item_name}
        </h1>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2">
          {(product.top_item ?? product.hot_item) && (
            <Badge variant="destructive" class="bg-orange-500 hover:bg-orange-600 font-comic-neue">Top items</Badge>
          )}
        </div>


        <!-- Description -->
        <div class="text-foreground leading-relaxed font-comic-neue">
          {product.item_description}
        </div>

        <!-- Product information (spec key/value table) -->
        {product.specifications.length > 0 && (
          <div class="space-y-3">
            <h3 class="font-semibold text-foreground font-fredoka">Product information</h3>
            <div class="grid grid-cols-1 gap-y-0 text-sm font-comic-neue">
              {product.specifications.map(spec => (
                <div class="flex justify-between py-1 border-b border-border">
                  <span class="font-medium text-muted-foreground">{spec.display_name}</span>
                  <span class="text-foreground text-right">{spec.value}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Awards -->
        {product.award_text.length > 0 && (
          <div class="space-y-3">
            <h3 class="font-semibold text-foreground font-fredoka">Awards</h3>
            <ul class="space-y-1.5 text-sm font-comic-neue">
              {product.award_text.map((award: string) => (
                <li class="text-muted-foreground">{award}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- Tags -->
        {product.tag_visible.length > 0 && (
          <div class="space-y-2">
            <h3 class="font-semibold text-foreground font-fredoka">Tags:</h3>
            <div class="flex flex-wrap gap-2">
              {product.tag_visible.map((tag: string) => (
                <span class="px-3 py-1 bg-muted text-muted-foreground text-sm rounded-full font-comic-neue">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Actions: share + multi-language download -->
        <div
          class:list={[
            'flex items-center pt-4 border-t border-border flex-wrap gap-y-3 gap-x-4',
            showProductSocial ? 'justify-between' : 'justify-end',
          ]}
        >
          {showProductSocial && (
            <ProductShare
              client:load
              shareUrl={Astro.url.href}
              productTitle={product.item_name}
              shareLine={shareLine}
              pinterestMediaUrl={thumbnail}
              pinterestDescription={`${product.item_name} - ${product.item_description}`}
            />
          )}

          <ManualDownloads 
            multiLanguage={product.multi_language} 
            itemCode={product.item_code}
          />
        </div>
      </div>
    </div>

    <!-- Related Products -->
    <RelatedProducts products={relatedProducts} />
  </div>
</Layout>