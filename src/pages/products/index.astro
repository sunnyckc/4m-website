---
import { Layout } from '@/layouts';
import { Breadcrumb } from '@/components';
import { ProductsCatalog } from '@/components/organisms';
import { getProductCategories, orderProductCategoriesByProductSequences } from '@/repositories/site';
import { getAllProducts } from '@/services/products';
import { getBase } from '@/config';

const categoriesData = await getProductCategories();
let categories = categoriesData.categories;
try {
  const products = await getAllProducts();
  categories = orderProductCategoriesByProductSequences(categories, products);
} catch (e) {
  console.warn('[products] Could not reorder categories from product sequences', e);
}
const base = getBase();
---

<Layout title="Products - My Store" description="Browse our complete collection of premium products">
  <div class="container-custom py-8">
    <Breadcrumb
      items={[
        { label: 'Home', href: `${base}/` },
        { label: 'Products' },
      ]}
    />
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-fun">Our Products</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
        Discover our complete collection of carefully curated educational toys and STEAM learning kits designed to inspire creativity and imagination.
      </p>
    </div>

    <ProductsCatalog categories={categories} base={base} />
  </div>
</Layout>
