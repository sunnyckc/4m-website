---
import Layout from '../../components/layout/Layout.astro';
import Card from '../../components/ui/card.astro';
import Button from '../../components/ui/button.astro';
import Badge from '../../components/ui/badge.astro';
import { getProducts, getCategoryById, getProductsByCategory, getProductThumbnail, getBase } from '../../data/helpers';

export async function getStaticPaths() {
  const products = await getProducts();
  const categories = [...new Set(products.map(p => p.category_main))];
  
  return categories.map(category => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const categoryData = await getCategoryById(category);
const products = await getProductsByCategory(category);

const base = getBase();

if (!categoryData) {
  return Astro.redirect(`${base}/products`);
}
---

<Layout title={`${categoryData.name} - Products`} description={categoryData.description}>
  <div class="container-custom py-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-8 text-sm">
      <a href={`${base}/`} class="text-muted-foreground hover:text-primary">Home</a>
      <span class="mx-2 text-muted-foreground">/</span>
      <a href={`${base}/products`} class="text-muted-foreground hover:text-primary">Products</a>
      <span class="mx-2 text-muted-foreground">/</span>
      <span class="text-primary font-medium">{categoryData.name}</span>
    </nav>

    <!-- Category Header -->
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold">{categoryData.name}</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        {categoryData.description}
      </p>
      <div class="flex justify-center">
        <Badge variant="secondary" class="text-sm">
          {products.length} product{products.length === 1 ? '' : 's'}
        </Badge>
      </div>
    </div>

    <!-- Subcategories -->
    {categoryData.subcategories.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4">Browse by Subcategory</h2>
        <div class="flex flex-wrap gap-3">
          {categoryData.subcategories.map(subcategory => {
            const subcategoryProducts = products.filter(p => p.category_sub === subcategory.id);
            return (
              <a 
                href={`${base}/products?category=${category}&subcategory=${subcategory.id}`}
                class="flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors"
              >
                <span class="font-medium">{subcategory.name}</span>
                <Badge variant="outline" class="text-xs">
                  {subcategoryProducts.length}
                </Badge>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- Products Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {products.map((product) => (
        <a href={`${base}/products/${product.folder_name}`} class="block">
          <Card class="product-card overflow-hidden hover:shadow-lg transition-all hover:-translate-y-1 cursor-pointer">
            <div class="aspect-square bg-muted relative overflow-hidden">
              <img 
                src={getProductThumbnail(product)} 
                alt={product.item_name}
                class="w-full h-full object-cover transition-transform duration-300 ease-in-out product-image"
                loading="lazy"
              />
            </div>
            <div class="p-4 space-y-3">
              <div class="space-y-2">
                <div class="flex items-center gap-2">
                  <Badge variant="secondary" class="text-xs">{product.category_sub}</Badge>
                  {product.hot_item && (
                    <Badge variant="destructive" class="bg-orange-500 hover:bg-orange-600 text-xs">
                      Hot
                    </Badge>
                  )}
                </div>
                <h3 class="font-semibold text-lg leading-tight">{product.item_name}</h3>
                {product.item_code && (
                  <p class="text-xs text-muted-foreground font-mono">{product.item_code}</p>
                )}
                <p class="text-sm text-muted-foreground line-clamp-2">{product.item_description}</p>
              </div>
            </div>
          </Card>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    {products.length === 0 && (
      <div class="text-center py-12">
        <p class="text-lg text-muted-foreground mb-4">No products found in this category.</p>
        <Button href={`${base}/products`} variant="outline">
          Browse All Products
        </Button>
      </div>
    )}

    <!-- Back to All Products -->
    <div class="text-center mt-12">
      <Button href={`${base}/products`} variant="outline">
        ← Back to All Products
      </Button>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Product Image Zoom Effect */
  .product-image {
    transition: transform 0.3s ease-in-out;
  }

  .product-card:hover .product-image {
    transform: scale(1.1);
  }
</style>