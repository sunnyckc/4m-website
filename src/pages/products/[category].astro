---
import { Layout } from '@/layouts';
import { Button, Badge } from '@/components';
import {
  getProducts,
  getProductsByCategory,
  getProductThumbnail,
} from '@/repositories/catalog';
import { getCategoryById } from '@/repositories/site';
import { getBase } from '@/config';

export async function getStaticPaths() {
  const products = await getProducts();
  const categories = [...new Set(products.map(p => p.category_main))];
  
  return categories.map(category => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const categoryData = await getCategoryById(category);
const products = await getProductsByCategory(category);

const base = getBase();

if (!categoryData) {
  return Astro.redirect(`${base}/products`);
}
---

<Layout title={`${categoryData.name} - Products`} description={categoryData.description}>
  <div class="page-section-bg">
  <div class="container-custom py-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-8 text-sm">
      <a href={`${base}/`} class="text-muted-foreground hover:text-primary">Home</a>
      <span class="mx-2 text-muted-foreground">/</span>
      <a href={`${base}/products`} class="text-muted-foreground hover:text-primary">Products</a>
      <span class="mx-2 text-muted-foreground">/</span>
      <span class="text-primary font-medium">{categoryData.name}</span>
    </nav>

    <!-- Category Header -->
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold">{categoryData.name}</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        {categoryData.description}
      </p>
      <div class="flex justify-center">
        <Badge variant="secondary" class="text-sm">
          {products.length} product{products.length === 1 ? '' : 's'}
        </Badge>
      </div>
    </div>

    <!-- Subcategories -->
    {categoryData.subcategories.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4">Browse by Subcategory</h2>
        <div class="flex flex-wrap gap-3">
          {categoryData.subcategories.map(subcategory => {
            const subcategoryProducts = products.filter(p => p.category_sub === subcategory.id);
            return (
              <a 
                href={`${base}/products?category=${category}&subcategory=${subcategory.id}`}
                class="flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors"
              >
                <span class="font-medium">{subcategory.name}</span>
                <Badge variant="outline" class="text-xs">
                  {subcategoryProducts.length}
                </Badge>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- Products Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5">
      {products.map((product) => (
        <a
          href={`${base}/products/${product.folder_name}`}
          class="group block origin-center rounded-md transition-transform duration-200 ease-out hover:scale-[1.02] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
          <div class="relative aspect-square w-full overflow-hidden rounded-md border border-border bg-muted">
            {product.hot_item && (
              <span class="pointer-events-none absolute right-1.5 top-1.5 z-10 inline-flex items-center rounded-full bg-orange-500 px-2 py-0.5 text-[10px] font-semibold leading-none text-white shadow-sm">
                Top seller
              </span>
            )}
            <img
              src={getProductThumbnail(product)}
              alt={product.item_name}
              class="h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
              loading="lazy"
            />
          </div>
          <p class="mt-2 px-0.5 text-center text-[11px] font-normal leading-snug text-muted-foreground line-clamp-3 group-hover:text-foreground transition-colors">
            {product.item_name}
          </p>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    {products.length === 0 && (
      <div class="text-center py-12">
        <p class="text-lg text-muted-foreground mb-4">No products found in this category.</p>
        <Button href={`${base}/products`} variant="outline">
          Browse All Products
        </Button>
      </div>
    )}

    <!-- Back to All Products -->
    <div class="text-center mt-12">
      <Button href={`${base}/products`} variant="outline">
        ← Back to All Products
      </Button>
    </div>
  </div>
  </div>
</Layout>