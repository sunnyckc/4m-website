---
import { Layout } from '@/layouts';
import { getContactInfo } from '@/repositories/site';

const contactInfo = await getContactInfo();
---

<Layout title="Contact Us - 4M" description="Get in touch with our team for support, questions, or feedback">
  <div class="container-custom py-8">
    <!-- Header -->
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-fun">Contact Us</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
        We'd love to hear from you. Send us a message and we'll respond as soon as possible to help with your educational toy needs.
      </p>
    </div>

    <!-- Contact Info Bar -->
    <div class="flex flex-wrap justify-center gap-8 mb-10 text-sm text-muted-foreground font-comic-neue">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>{contactInfo.contact.address.full}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <a href={`mailto:${contactInfo.contact.email.primary}`} class="hover:text-primary transition-colors">{contactInfo.contact.email.display}</a>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <span>{contactInfo.contact.phone.display}</span>
      </div>
    </div>

    <!-- Enquiry Form (iframe from old site) -->
    <div class="w-full rounded-lg overflow-hidden border border-border shadow-sm">
      <iframe
        src="https://enquiry.4m-ind.com/contact_iFrame_v3.php"
        class="w-full border-0"
        style="height: 900px; overflow: hidden;"
        title="Contact Enquiry Form"
        loading="lazy"
      >
        Your browser does not support iframes.
      </iframe>
    </div>
  </div>
</Layout>
