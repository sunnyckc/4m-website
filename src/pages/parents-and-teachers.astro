---
import { Layout } from '@/layouts';
import { Button } from '@/components';
import { getBase } from '@/config';

const base = getBase();

const links = {
  products: `${base}/products`,
  steam: `${base}/steam`,
  greenScience: `${base}/products?category=science-education&subcategory=green-science`,
} as const;

const textLinkClass =
  'inline-flex items-center gap-1 font-medium text-blue-600 underline decoration-blue-600/80 underline-offset-[5px] hover:text-blue-800 hover:decoration-blue-800 dark:text-blue-400 dark:decoration-blue-400/70 dark:hover:text-blue-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm';
---

<Layout
  title="For parents & teachers - 4M STEAM & educational toys"
  description="Hands-on 4M kits for home and classroom—STEAM, Green Science, creativity, and environmental awareness for curious kids."
>
  <div class="container-custom py-8">
    <nav class="mb-8 flex text-sm" aria-label="Breadcrumb">
      <a href={`${base}/`} class="text-muted-foreground hover:text-primary">Home</a>
      <span class="mx-2 text-muted-foreground">/</span>
      <span class="text-primary font-medium">Parents &amp; teachers</span>
    </nav>

    <div class="mx-auto max-w-3xl space-y-6 text-center mb-14 lg:mb-20">
      <h1 class="text-3xl font-bold text-fun md:text-4xl">Parents &amp; teachers</h1>
      <p class="text-lg text-muted-foreground text-comic">
        Whether you are guiding one child at the kitchen table or a whole class in the lab, the same idea applies: learning sticks when hands are busy and questions lead the way. Here is how we think about play, STEAM, and the planet—so you can choose kits that fit your setting.
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-2">
        <Button href={links.products} size="lg" class="font-fredoka btn-bouncy">
          Browse products
        </Button>
        <Button href={links.steam} size="lg" variant="outline" class="font-fredoka btn-bouncy">
          STEAM education
        </Button>
      </div>
    </div>
  </div>

  <section
    class="pb-14 lg:pb-24 overflow-hidden"
    aria-label="Learning at home and in the classroom"
  >
    <div class="container-custom">
      <div class="flex flex-col gap-20 lg:gap-28">
        <!-- 1: visual left, copy right — benefit to the child -->
        <article
          class="home-pillar-row grid lg:grid-cols-2 gap-10 lg:gap-16 xl:gap-20 items-center"
          data-audience-section="child-benefit"
        >
          <div
            class="home-pillar-visual min-h-[240px] sm:min-h-[300px] lg:min-h-[340px] xl:min-h-[400px] w-full rounded-2xl border border-dashed border-muted-foreground/20 bg-gradient-to-br from-amber-200/85 via-orange-300/50 to-rose-300/45 dark:from-amber-900/40 dark:via-orange-950/35 dark:to-rose-950/35 shadow-sm"
            role="img"
            aria-label="Placeholder: children learning together at home or school"
          />
          <div class="space-y-5 lg:max-w-xl lg:justify-self-end text-center lg:text-left">
            <h3 class="text-2xl md:text-3xl font-bold text-fun">What changes for the child</h3>
            <p class="text-lg text-muted-foreground text-comic leading-relaxed">
              Hands-on kits turn abstract ideas into something they can touch—sequence, cause and effect, and “what happens if?” become real. Kids practice patience when a build fails the first time, pride when it works, and language to explain what they noticed. At home that might be a quiet hour of focus; at school it might be teamwork and taking turns—same skills, different scale.
            </p>
          </div>
        </article>

        <!-- 2: copy left, visual right — Green Science -->
        <article
          class="home-pillar-row grid lg:grid-cols-2 gap-10 lg:gap-16 xl:gap-20 items-center"
          data-audience-section="green-science"
        >
          <div class="space-y-5 lg:max-w-xl order-2 lg:order-1 text-center lg:text-left">
            <h3 class="text-2xl md:text-3xl font-bold text-fun">Why Green Science belongs in the mix</h3>
            <p class="text-lg text-muted-foreground text-comic leading-relaxed">
              Green Science lines connect everyday materials, energy, and ecosystems to projects kids actually finish. They learn that “green” is not a slogan—it is design choices, trade-offs, and caring for the systems we depend on. That mindset travels from the workbench to how they see water, waste, and wildlife.
            </p>
            <p class="text-center lg:text-left">
              <a href={links.greenScience} class={textLinkClass}>
                Explore Green Science products
                <span aria-hidden="true">→</span>
              </a>
            </p>
          </div>
          <div
            class="home-pillar-visual min-h-[240px] sm:min-h-[300px] lg:min-h-[340px] xl:min-h-[400px] w-full rounded-2xl border border-dashed border-muted-foreground/20 bg-gradient-to-br from-lime-200/90 to-emerald-600/35 dark:from-lime-900/40 dark:to-emerald-950/60 shadow-sm order-1 lg:order-2"
            role="img"
            aria-label="Placeholder: eco-minded science projects and outdoor discovery"
          />
        </article>

        <!-- 3: visual left, copy right — STEAM -->
        <article
          class="home-pillar-row grid lg:grid-cols-2 gap-10 lg:gap-16 xl:gap-20 items-center"
          data-audience-section="steam"
        >
          <div
            class="home-pillar-visual min-h-[240px] sm:min-h-[300px] lg:min-h-[340px] xl:min-h-[400px] w-full rounded-2xl border border-dashed border-muted-foreground/20 bg-gradient-to-br from-sky-200/90 to-indigo-500/40 dark:from-sky-900/50 dark:to-indigo-950/60 shadow-sm"
            role="img"
            aria-label="Placeholder: engineering, science, and creative problem-solving"
          />
          <div class="space-y-5 lg:max-w-xl lg:justify-self-end text-center lg:text-left">
            <h3 class="text-2xl md:text-3xl font-bold text-fun">Why STEAM, not just a single subject</h3>
            <p class="text-lg text-muted-foreground text-comic leading-relaxed">
              Real problems rarely arrive labeled “math” or “art.” STEAM-style kits blend observation, measurement, building, and expression so learners practice the whole loop: hypothesize, try, adjust, communicate. Parents get a structured way to support curiosity; teachers get anchors for inquiry without losing the joy of play.
            </p>
            <p class="text-center lg:text-left">
              <a href={links.steam} class={textLinkClass}>
                Read how we approach STEAM
                <span aria-hidden="true">→</span>
              </a>
            </p>
          </div>
        </article>

        <!-- 4: copy left, visual right — environment & creativity -->
        <article
          class="home-pillar-row grid lg:grid-cols-2 gap-10 lg:gap-16 xl:gap-20 items-center"
          data-audience-section="environment-creativity"
        >
          <div class="space-y-5 lg:max-w-xl order-2 lg:order-1 text-center lg:text-left">
            <h3 class="text-2xl md:text-3xl font-bold text-fun">Environment, awareness, and creative nerve</h3>
            <p class="text-lg text-muted-foreground text-comic leading-relaxed">
              We want kids to notice the world more closely—to sketch an idea, test a silly prototype, and ask where materials come from and where they go. That blend of environmental awareness and creative nerve is how habits form: resourceful making, respect for safety, and the confidence to try again. Your role is simply to make space for the mess and the conversation that follows.
            </p>
            <p class="text-center lg:text-left">
              <a href={links.products} class={textLinkClass}>
                Find a kit for your learners
                <span aria-hidden="true">→</span>
              </a>
            </p>
          </div>
          <div
            class="home-pillar-visual min-h-[240px] sm:min-h-[300px] lg:min-h-[340px] xl:min-h-[400px] w-full rounded-2xl border border-dashed border-muted-foreground/20 bg-gradient-to-br from-teal-200/90 to-cyan-600/35 dark:from-teal-900/45 dark:to-cyan-950/55 shadow-sm order-1 lg:order-2"
            role="img"
            aria-label="Placeholder: nature observation, creativity, and sustainable making"
          />
        </article>
      </div>
    </div>
  </section>
</Layout>
