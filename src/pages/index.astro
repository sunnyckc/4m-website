---
import { Layout } from '@/layouts';
import {
  Button,
  Card,
  Badge,
  HeroBannerSlider,
  HeroFullViewport,
  HeroOrbitBanner,
  GalleryGrid,
  CatalogSlider,
} from '@/components';
import { getHotProducts, getProductThumbnail } from '@/repositories/catalog';
import { getFeaturedAwards } from '@/repositories/awards';
import {
  getHomeCatalogHot,
  getHomeGallerySteam,
  getHomeHero,
  getSiteLinks,
} from '@/repositories/site';
import { getBase } from '@/config';
import { getFeaturedNews } from '@/repositories/news';
import type { CatalogSliderItem } from '@/components/organisms/home';
import { formatDate } from '@/utils';

const hotProducts = await getHotProducts();
const featuredAwards = await getFeaturedAwards();
const featuredNews = await getFeaturedNews();
const siteLinks = await getSiteLinks();
const base = getBase();
const homeHero = await getHomeHero();
const homeGallerySteam = await getHomeGallerySteam();
const homeCatalogHot = await getHomeCatalogHot();

/** Full-viewport / orbit heroes sit flush; slider keeps spacing before the next section. */
const immersiveHero =
  (homeHero.variant === 'fullViewport' && homeHero.fullViewport != null) ||
  (homeHero.variant === 'orbitBanner' && homeHero.orbitBanner != null);

const hotCatalogItems: CatalogSliderItem[] = hotProducts.map((p) => ({
  id: p.folder_name,
  textPrimary: p.item_name,
  textSecondary: p.item_description,
  imageUrl: getProductThumbnail(p) || undefined,
  imageAlt: p.item_name,
  hoverText: `View ${p.item_name}`,
  href: `${base}/products/${p.folder_name}`,
  batches: [
    { label: p.category_main.replace(/-/g, ' ') },
    ...(p.hot_item ? [{ label: 'Hot' as const }] : []),
  ],
}));
---

<Layout
  title="4M Industrial Development Limited - STEAM Educational Toys"
  description="4M Industrial Development Limited - Award-winning educational toys and STEAM learning products. Inspiring creativity, critical thinking, and innovation in children through hands-on educational play experiences."
  revealHeaderOnScroll={immersiveHero}
>
  <!-- Hero: each variant owns its root element and vertical spacing (no page-level wrapper). -->
  {homeHero.variant === 'orbitBanner' && homeHero.orbitBanner ? (
    <HeroOrbitBanner
      client:load
      config={homeHero.orbitBanner}
      showTuner={import.meta.env.DEV}
    />
  ) : homeHero.variant === 'fullViewport' && homeHero.fullViewport ? (
    <HeroFullViewport
      client:load
      title={homeHero.fullViewport.title}
      subtitle={homeHero.fullViewport.subtitle}
      ctaText={homeHero.fullViewport.ctaText}
      ctaHref={homeHero.fullViewport.ctaHref}
      background={homeHero.fullViewport.background}
      className={homeHero.fullViewport.className}
      innerClassName={homeHero.fullViewport.innerClassName}
      minHeightClassName={homeHero.fullViewport.minHeightClassName}
      mediaSlotMinHeightClassName={homeHero.fullViewport.mediaSlotMinHeightClassName}
      showMediaSlot={homeHero.fullViewport.showMediaSlot ?? true}
    />
  ) : (
    <HeroBannerSlider
      client:load
      slides={homeHero.slides}
      autoplay={homeHero.options?.autoplay ?? true}
      autoplayDelayMs={homeHero.options?.autoplayDelayMs ?? 5000}
      showDots={homeHero.options?.showDots ?? true}
      showArrows={homeHero.options?.showArrows ?? true}
      className={homeHero.options?.className}
      heightClassName={homeHero.options?.heightClassName}
      loop={homeHero.options?.loop ?? true}
    />
  )}

  <!-- Steam Education Section -->
  <section class="py-8 lg:py-12">
    <div class="container-custom">
      <div class="text-center space-y-4 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-fun">{homeGallerySteam.title}</h2>
        {homeGallerySteam.description ? (
          <p class="text-lg text-muted-foreground max-w-3xl mx-auto text-comic">
            {homeGallerySteam.description}
          </p>
        ) : null}
      </div>

      <GalleryGrid
        client:load
        items={homeGallerySteam.items}
        gridClassName={homeGallerySteam.layout?.gridClassName ?? 'grid-cols-1 md:grid-cols-3'}
        gapClassName={homeGallerySteam.layout?.gapClassName ?? 'gap-2'}
        className={homeGallerySteam.layout?.className ?? 'w-full max-w-4xl mx-auto'}
      />
    </div>
  </section>

  <!-- Hot Products Section -->
  {hotProducts.length > 0 && (
    <section class="py-16 lg:py-24 bg-muted/30">
      <div class="container-custom">
        <div class="text-center space-y-4 mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-fun">{homeCatalogHot.title}</h2>
          {homeCatalogHot.description ? (
            <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
              {homeCatalogHot.description}
            </p>
          ) : null}
        </div>

        <CatalogSlider
          client:load
          items={hotCatalogItems}
          itemsPerSlide={homeCatalogHot.carousel.itemsPerSlide}
          initialSlideIndex={homeCatalogHot.carousel.initialSlideIndex ?? 0}
          showArrows={homeCatalogHot.carousel.showArrows ?? true}
          showDots={
            (homeCatalogHot.carousel.showDots ?? true) &&
            hotCatalogItems.length > homeCatalogHot.carousel.itemsPerSlide
          }
          slideGridClassName={homeCatalogHot.carousel.slideGridClassName}
        />

        <div class="flex justify-center items-center gap-4 mt-12 flex-wrap">
          <Button href={`${base}/products`} size="lg" class="font-fredoka btn-bouncy">
            View All Products
          </Button>
          {siteLinks.catalog_buttons.map((btn) => (
            <Button href={btn.url} size="lg" variant="outline" class="font-fredoka btn-bouncy" target="_blank" rel="noopener noreferrer">
              {btn.label}
            </Button>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- Awards Section -->
  {featuredAwards.length > 0 && (
    <section class="py-16 lg:py-24 bg-muted/50">
      <div class="container-custom">
        <div class="text-center space-y-4 mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-fun">Award-Winning Excellence</h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
            Our commitment to quality and innovation has been recognized by industry leaders.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
          {featuredAwards.map((award) => (
            <Card class="text-center p-8 hover:shadow-lg transition-shadow">
              {award.media_source === 'file' && award.media_destination && (
                <div class="w-16 h-16 mx-auto mb-4 bg-primary/10 rounded-full flex items-center justify-center">
                  <img src={`${base}/images/awards/${award.media_destination}`} alt={award.name} class="w-8 h-8" />
                </div>
              )}
              <h3 class="text-xl font-semibold mb-2">{award.name}</h3>
              <p class="text-muted-foreground mb-4">{award.program}</p>
              <div class="text-sm text-muted-foreground">
                <div>{award.institution}</div>
                <div>{award.year}</div>
              </div>
            </Card>
          ))}
        </div>

        <div class="text-center">
          <Button href={`${base}/awards`} variant="outline">
            View All Awards
          </Button>
        </div>
      </div>
    </section>
  )}

  <!-- Latest News -->
  {featuredNews.length > 0 && (
    <section class="py-16 lg:py-24">
      <div class="container-custom">
        <div class="text-center space-y-4 mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-fun">Latest News</h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
            Stay updated with our latest announcements, product launches, and company news.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
          {featuredNews.map((post) => (
            <Card class="overflow-hidden hover:shadow-lg transition-shadow">
              <div class="aspect-video bg-muted">
                <img 
                  src={post.image ? (post.image.startsWith('http') ? post.image : `${base}${post.image}`) : `${base}/images/news/default-news.jpg`} 
                  alt={post.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="p-6 space-y-4">
                <div class="space-y-2">
                  <Badge variant="outline">{post.category}</Badge>
                  <h3 class="text-xl font-semibold">{post.title}</h3>
                  <p class="text-muted-foreground">{post.excerpt}</p>
                </div>
                <div class="flex items-center justify-between text-sm text-muted-foreground">
                  <span>{formatDate(post.date)}</span>
                  <Button href={`${base}/news/${post.id}`} variant="ghost" size="sm">
                    Read More →
                  </Button>
                </div>
              </div>
            </Card>
          ))}
        </div>

        <div class="text-center">
          <Button href={`${base}/news`} variant="outline">
            View All News
          </Button>
        </div>
      </div>
    </section>
  )}
</Layout>