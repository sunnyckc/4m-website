---
import Layout from '../../components/layout/Layout.astro';
import { getAllNews, formatDate } from '../../data/news.ts';
import { getBase } from '../../data/helpers';

const base = getBase();

// Load news data
const sortedNews = await getAllNews();
---

<Layout title="News | 4M Industrial Development Limited" description="Latest news and updates from 4M Industrial Development Limited - awards, product launches, and company achievements.">
  <div class="container-custom py-8">
    <!-- Header -->
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-fun">News</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
        Stay updated with our latest achievements, product launches, and industry recognition as we continue our journey of innovation and excellence.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedNews.map((article) => (
          <div class="bg-card rounded-lg border shadow-sm hover:shadow-md transition-shadow overflow-hidden">
            <div class="aspect-video bg-muted relative overflow-hidden">
              <img 
                src={article.image ? (article.image.startsWith('http') ? article.image : `${base}${article.image}`) : `${base}/images/news/default-news.jpg`} 
                alt={article.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-primary text-primary-foreground px-2 py-1 rounded text-xs font-medium">
                  {article.category}
                </span>
              </div>
            </div>
            <div class="p-4">
              <div class="mb-2">
                <time class="text-xs text-muted-foreground font-medium">
                  {article.date}
                </time>
              </div>
              <h3 class="text-sm font-semibold mb-2 leading-tight">
                <a href={`${base}/news/${article.id}`} class="hover:text-primary transition-colors">
                  {article.title}
                </a>
              </h3>
              <p class="text-xs text-muted-foreground mb-3 line-clamp-3">
                {article.excerpt}
              </p>
              <div class="flex justify-between items-center">
                <a 
                  href={`${base}/news/${article.id}`}
                  class="text-xs font-medium text-primary hover:underline"
                >
                  Read More
                </a>
              </div>
            </div>
          </div>
        ))}
    </div>
  </div>
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>