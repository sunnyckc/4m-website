---
import Layout from '../../components/layout/Layout.astro';
import NewsCard from '../../components/news/NewsCard.astro';
import { getAllNews, getRelatedNews, formatContent, formatDate } from '../../data/news.ts';

export async function getStaticPaths() {
  const newsData = await getAllNews();
  
  return newsData.map((article) => ({
    params: { id: article.id },
    props: { article }
  }));
}

const { article } = Astro.props;

// Get related articles (same category, excluding current)
const relatedArticles = await getRelatedNews(article.id, article.category, 3);
---

<Layout 
  title={`${article.title} | 4M Industrial Development Limited`} 
  description={article.excerpt}
  image={article.image}
>
  
  <main class="min-h-screen bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
    <!-- Breadcrumb -->
    <nav class="py-4 bg-white/80 backdrop-blur-sm sticky top-20 z-40 border-b">
      <div class="container-custom">
        <ol class="flex items-center space-x-2 text-sm">
          <li><a href="/" class="text-blue-600 hover:text-blue-800">Home</a></li>
          <li class="text-gray-400">/</li>
          <li><a href="/news" class="text-blue-600 hover:text-blue-800">News</a></li>
          <li class="text-gray-400">/</li>
          <li class="text-gray-600 truncate">{article.title}</li>
        </ol>
      </div>
    </nav>

    <article class="py-12">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          <!-- Article Header -->
          <header class="mb-12">
            <div class="flex items-center gap-4 mb-6">
              <span class="inline-block px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-full">
                {article.category}
              </span>
              <time class="text-blue-600 font-semibold">
                {article.date}
              </time>
              {article.featured && (
                <span class="inline-block px-4 py-2 bg-yellow-500 text-white text-sm font-semibold rounded-full">
                  Featured
                </span>
              )}
            </div>
            
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 font-fredoka leading-tight">
              {article.title}
            </h1>
            
            <p class="text-xl text-gray-600 leading-relaxed font-comic-neue">
              {article.excerpt}
            </p>
          </header>

          <!-- Featured Image -->
          <div class="mb-12 rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src={article.image || '/images/news/default-news.jpg'} 
              alt={article.title}
              class="w-full h-64 md:h-96 object-cover"
            />
          </div>

          <!-- Article Content -->
          <div class="prose prose-lg max-w-none">
            <div class="text-lg font-comic-neue" set:html={formatContent(article.content)}></div>
          </div>

          <!-- Share Buttons -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Share this article</h3>
            <div class="flex gap-4">
              <button 
                class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-full hover:bg-blue-700 transition-colors"
                onclick={`window.open('https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(Astro.url.toString())}', '_blank')`}
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                </svg>
                Twitter
              </button>
              
              <button 
                class="flex items-center gap-2 px-4 py-2 bg-blue-800 text-white rounded-full hover:bg-blue-900 transition-colors"
                onclick={`window.open('https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}', '_blank')`}
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </button>
              
              <button 
                class="flex items-center gap-2 px-4 py-2 bg-blue-700 text-white rounded-full hover:bg-blue-800 transition-colors"
                onclick={`window.open('https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}', '_blank')`}
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </button>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- Related Articles -->
    {relatedArticles.length > 0 && (
      <section class="py-16 bg-white/50">
        <div class="container-custom">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold text-gray-900 mb-8 font-fredoka">Related News</h2>
            
            <div class="grid md:grid-cols-3 gap-6">
              {relatedArticles.map((related) => (
                <NewsCard article={related} size="small" />
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Back to News -->
    <section class="py-8">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto text-center">
          <a 
            href="/news" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold rounded-full hover:from-blue-700 hover:to-purple-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            <svg class="w-4 h-4 transform rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            Back to All News
          </a>
        </div>
      </div>
    </section>
  </main>

</Layout>

<style>
  .container-custom {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prose {
    @apply text-gray-700;
  }

  .prose h2 {
    @apply text-2xl font-bold text-gray-900 mt-8 mb-4 font-fredoka;
  }

  .prose p {
    @apply mb-6 leading-relaxed;
  }

  .prose a {
    @apply text-blue-600 hover:text-blue-800 underline;
  }
</style>