---
import Layout from '../components/layout/Layout.astro';
import { getAwards, getBase } from '../data/helpers';

const base = getBase();
const awards = await getAwards();
---

<Layout title="Awards | 4M Industrial Development Limited">
  <div class="container-custom py-8">
    <!-- Header -->
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-fun">Awards</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
        Recognition for Excellence and Innovation - Commitment and collaboration have helped us win more than 70 local and international awards since 2003.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {awards.map((award) => (
          <div class="bg-card rounded-lg border shadow-sm hover:shadow-md transition-shadow p-4 text-center">
            {award.media_source === 'file' && award.media_destination && (
              <div class="mb-3 flex justify-center">
                <img 
                  src={`${base}/images/awards/${award.media_destination}`} 
                  alt={award.name}
                  class="h-16 w-auto object-contain"
                  loading="lazy"
                />
              </div>
            )}
            <h5 class="text-sm font-semibold mb-2">{award.name}</h5>
            <p class="text-xs text-muted-foreground mb-1">{award.program}</p>
            <p class="text-xs text-muted-foreground mb-2">{award.institution}</p>
            <div class="text-center">
              <span class="text-xs font-medium text-primary">{award.year}</span>
            </div>
          </div>
        ))}
    </div>
  </div>
</Layout>
