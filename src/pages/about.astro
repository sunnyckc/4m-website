---
import Layout from '../components/layout/Layout.astro';
import Card from '../components/ui/card.astro';
import HeroSlideshow from '../components/ui/hero-slideshow.astro';
import { getBase } from '../data/helpers';

const base = getBase();

const heroSlides = [
  {
    id: "4m-hero",
    image: `${base}/images/4m-assets/New_Project_(60).png`,
    title: "4M - For Minds",
    subtitle: "Helping children develop creativity and imagination since 1993"
  }
];
---

<Layout title="About Us - 4M Industrial Development Limited" description="Learn about 4M's mission to help children develop creativity and imagination through innovative educational toys">
  <!-- Hero Section with Image -->
  <HeroSlideshow 
    slides={heroSlides} 
    autoplay={false} 
    showIndicators={false} 
    showArrows={false}
    class="mb-16"
  />

  <div class="container-custom py-8">
    <!-- Main About Section -->
    <div class="text-center space-y-4 mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-fun">About 4M</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
        4M has been helping children develop their creativity and imagination since our first product hit the market in 1993. 
        We create high quality toys and crafts that are imaginative, creative, inspiring and fun.
      </p>
    </div>

    <!-- 4M - For Minds Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
      <div class="space-y-6">
        <h2 class="text-3xl md:text-4xl font-bold text-fun">4M – For Minds</h2>
        <p class="text-lg text-muted-foreground text-comic">
          Following the huge success of Jumbo Chalk and our popular glow-in-the-dark products, we branched into scientific educational toys in 1999 with the launch of Kidz Labs. Now in our third decade of operations, we continue to innovate and manufacture premium products that stimulate mental development.
        </p>
        <p class="text-lg text-muted-foreground text-comic">
          Our 300-strong product catalogue is continually revamped by our home-grown Hong Kong design team. We are proud to now be in specialty boutiques, museum shops and up-market department stores in more than 80 countries around the world.
        </p>
      </div>
      <div class="aspect-square rounded-lg overflow-hidden">
        <img 
          src={`${base}/images/4m-assets/About_Us_2.jpg`} 
          alt="4M Educational Products" 
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Four Minds Section -->
    <div class="mb-16">
      <div class="text-center space-y-4 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-fun">4M – Four Minds</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
          Imaginative, creative, inspiring and fun are the 4 core principles that birthed 4M; characteristics that are in our people, our designs, and throughout our production process. These are the essential elements of healthy mental development that we hope to instill in every precious young mind:
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="p-8 text-center group cursor-pointer">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2L3 7v11a1 1 0 001 1h3a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1h3a1 1 0 001-1V7l-7-5z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Imaginative</h3>
          <p class="text-muted-foreground">
            With an imaginative mind, we can see the world for what it is and what it might be.
          </p>
        </div>

        <div class="p-8 text-center group cursor-pointer">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Inspiring</h3>
          <p class="text-muted-foreground">
            With an inspiring mind, we have the courage to explore new horizons and face challenges.
          </p>
        </div>

        <div class="p-8 text-center group cursor-pointer">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Creative</h3>
          <p class="text-muted-foreground">
            With a creative mind, we dream up innovative solutions to overcome life's obstacles.
          </p>
        </div>

        <div class="p-8 text-center group cursor-pointer">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM7 9a1 1 0 100-2 1 1 0 000 2zm7-1a1 1 0 11-2 0 1 1 0 012 0zm-.464 5.535a1 1 0 10-1.415-1.414 3 3 0 01-4.242 0 1 1 0 00-1.415 1.414 5 5 0 007.072 0z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Fun</h3>
          <p class="text-muted-foreground">
            With a fun mind, we appreciate and savour our world full of wonders, every day.
          </p>
        </div>
      </div>
    </div>

    <!-- For Young Minds Section -->
    <div class="text-center bg-muted/30 rounded-2xl p-12">
      <div class="space-y-4 mb-8">
        <h2 class="text-3xl md:text-4xl font-bold text-fun">For Young Minds</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
          The development of executive brain function is a critical aspect of children's education, influencing their ability to learn and process information for the rest of their lives.
        </p>
      </div>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto text-comic">
        Our educational toys, through easy to use yet sophisticated applied science and crafts, spark and engage the higher brain activities that make us successful thinkers: logic, inference, analysis, and imagination.
      </p>
    </div>

  </div>
</Layout>